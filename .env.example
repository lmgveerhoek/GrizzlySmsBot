GRIZZLY_API_KEY=replace_with_your_key
SERVICE=wx
COUNTRY=62
MAX_PRICE=2
PROVIDER_IDS=311

DISCORD_WEBHOOK_URL=replace_with_discord_webhook_url
DISCORD_MAX_RETRIES=5
# Optional redundant delivery through ntfy.
NTFY_URL=
NTFY_MAX_RETRIES=5

# One activation is acquired per run. The process exits after it completes or fails.
MAX_REQUESTS_PER_SECOND=5
REQUEST_TIMEOUT_SECONDS=10
STATUS_EVERY_REQUESTS=100
SMS_POLL_SECONDS=5
ACTIVATION_TIMEOUT_SECONDS=900
# Docker uses /data/grizzlysms.db; use a local path when running without Docker.
STATE_DB_PATH=/data/grizzlysms.db
LOG_LEVEL=INFO
